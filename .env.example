# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development           # development | paper | semi-auto | live
LOG_LEVEL=INFO

# ── Capital & Risk (under ₹1L) ────────────────────────────────────────────────
TOTAL_CAPITAL=100000          # Total capital in INR (₹1,00,000)
MAX_RISK_PER_TRADE_PCT=2.0    # Max % of capital to risk per trade (₹2,000)
DAILY_LOSS_LIMIT_PCT=2.0      # Halt trading if day loss exceeds this % (₹2,000)
MAX_OPEN_POSITIONS=8
MAX_POSITION_SIZE_PCT=10.0    # Max % of capital in single position (₹10,000)

# ── Database ──────────────────────────────────────────────────────────────────
DB_USER=trading
DB_PASSWORD=trading_secret
DB_NAME=trading_bot
DB_HOST=localhost
DB_PORT=5432
DATABASE_URL=postgresql+asyncpg://trading:trading_secret@localhost:5432/trading_bot

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret
REDIS_URL=redis://:redis_secret@localhost:6379/0

# ── Zerodha Kite Connect ──────────────────────────────────────────────────────
# Get these from: https://kite.trade  (₹2000/month developer account)
KITE_API_KEY=your_kite_api_key_here
KITE_API_SECRET=your_kite_api_secret_here
KITE_USER_ID=your_zerodha_user_id        # e.g. AB1234
KITE_PASSWORD=your_zerodha_password
KITE_TOTP_SECRET=your_totp_secret_key    # From Zerodha 2FA setup (base32 key)
# Access token is auto-refreshed daily — no need to set manually

# ── Groww Trade API ───────────────────────────────────────────────────────────
# Get from: Groww app → Settings → Trade API (₹499/month)
GROWW_API_KEY=your_groww_api_key_here
GROWW_API_SECRET=your_groww_api_secret_here

# ── Anthropic / Claude ────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-opus-4-6          # or claude-sonnet-4-6 for faster/cheaper

# ── Telegram Bot ─────────────────────────────────────────────────────────────
# Step 1: Create a bot → message @BotFather on Telegram → /newbot → copy token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Step 2: Who receives notifications?
# Option A — Single chat (personal DM or group): get ID from @userinfobot
TELEGRAM_CHAT_ID=your_chat_id_here
# Option B — Multiple recipients: comma-separated IDs (overrides TELEGRAM_CHAT_ID)
# Group chat IDs start with -100...  |  Personal IDs are positive numbers
# TELEGRAM_CHAT_IDS=123456789,987654321,-100112233445

# Step 3: Who can use bot commands (/status, /pnl, /positions) and approve trades?
# Comma-separated Telegram USER IDs (not chat IDs) — get from @userinfobot
# Leave blank = anyone can use commands (only safe on private/personal bots)
TELEGRAM_AUTHORIZED_IDS=

# ── Semi-auto mode (only needed when APP_ENV=semi-auto) ───────────────────────
APPROVAL_TIMEOUT_SECS=60              # Auto-reject after this many seconds

# ── News API ──────────────────────────────────────────────────────────────────
# Free tier: https://newsapi.org (100 requests/day)
NEWS_API_KEY=your_newsapi_key_here
